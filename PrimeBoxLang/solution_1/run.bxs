import sieve;

limit = 1000000;
passes = 0;
runTime = 5000; // 5 seconds in milliseconds

startTime = GetTickCount(); // convert to ms

do {
    nsieve = new Sieve( limit );
    nsieve.runSieve();
    passes++;
} while ( GetTickCount() - startTime < runTime );

 if (isObject(nsieve)) {
        delta = getTickCount() - startTime;
        duration = delta / 1000;

        nsieve.printResults(duration, passes);
    }